# Override language detection for better accuracy
# Frontend files
frontend/src/**/* linguist-language=TypeScript
frontend/src/**/*.tsx linguist-language=TSX
frontend/src/**/*.ts linguist-language=TypeScript

# Backend files  
backend/src/**/*.ts linguist-language=TypeScript

# Config files
*.json linguist-vendored
*.lock linguist-vendored
*.config.* linguist-vendored
